# ─────────────────────────────────────────────────────────────
# OTLive — .gitattributes
# 跨平台统一换行符（Windows / macOS / Linux）
# ─────────────────────────────────────────────────────────────

# 默认：仓库内统一使用 LF 换行
* text=auto eol=lf

# 文本源码显式声明 / Explicit text types
*.py     text eol=lf
*.pyi    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.sql    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.php    text eol=lf
*.csv    text eol=lf
*.spec   text eol=lf
# Windows 脚本保持 CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
*.vbs    text eol=crlf
.gitignore       text eol=lf
.gitattributes   text eol=lf

# C/C++（ESP32 固件）
*.cpp    text eol=lf
*.c      text eol=lf
*.h      text eol=lf
*.hpp    text eol=lf

# PlatformIO 配置
*.ini    text eol=lf
platformio.ini  text eol=lf

# 二进制资源 / Binary assets（不做行尾转换）
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.bmp    binary
*.wav    binary
*.mp3    binary
*.exe    binary
*.dll    binary
*.zip    binary
*.pyc    binary
*.pyz    binary
*.db     binary
*.eot    binary
*.ttf    binary
*.woff   binary
*.woff2  binary
*.svg    text eol=lf
