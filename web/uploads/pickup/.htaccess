# 禁止直接访问图片（通过PHP验证后访问）
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_REFERER} !^https://ex.hzjt.com [NC]
    RewriteRule .* - [F,L]
</IfModule>

# 禁止执行PHP
<FilesMatch "\.(php|php\.|php3|php4|phtml|pl|py|jsp|asp|aspx|cgi|sh|bash)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 只允许图片文件
<FilesMatch "\.(jpg|jpeg|png|gif)$">
    Order allow,deny
    Allow from all
</FilesMatch>
